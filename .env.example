# Application
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Database connection (Prisma uses DATABASE_URL)
DATABASE_URL=postgresql://postgres:postgres@db:5432/items_db

# Individual DB variables (used to build DATABASE_URL if not provided)
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=items_db

# Postgres container variables (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=items_db

# Seed (migrations are manual: npm run db:migrate)
RUN_SEED=true
