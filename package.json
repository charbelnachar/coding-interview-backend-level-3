{
  "name": "coding-interview-backend-level-3",
  "version": "1.0.0",
  "description": "Coding Interview Backend Level 3",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest e2e --forceExit",
    "test:unit": "jest test/unit --forceExit",
    "test:integration": "jest test/integration --forceExit",
    "test:all": "jest --testPathPattern='(e2e|test)' --forceExit",
    "lint": "biome lint src test e2e",
    "lint:fix": "biome lint --write src test e2e",
    "format": "biome format --write src test e2e",
    "format:check": "biome format src test e2e",
    "check": "biome check src test e2e",
    "check:fix": "biome check --write src test e2e",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "ts-node src/database/seeds/seed.ts",
    "prepare": "husky"
  },
  "author": "El Dorado Dev Team",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@hapi/hapi": "^21.3.10",
    "@swc/core": "^1.7.2",
    "@swc/jest": "^0.2.36",
    "@types/express": "^5.0.0",
    "@types/hapi__hapi": "^20.0.13",
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.10",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.1"
  },
  "lint-staged": {
    "*.{ts,js,json}": ["biome check --write --no-errors-on-unmatched"]
  }
}
